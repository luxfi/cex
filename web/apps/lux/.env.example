# Lux Exchange - Environment Configuration
# Copy this to .env.local and fill in values

# --- Brand (white-label) ---
NEXT_PUBLIC_BRAND_NAME="Lux Exchange"
NEXT_PUBLIC_BRAND_SHORT_NAME="Lux"
NEXT_PUBLIC_BRAND_TAGLINE="Trade Everything. $0 Commission."
NEXT_PUBLIC_BRAND_DESCRIPTION="Trade stocks, crypto, options, and more with $0 commission."

# --- Identity (Lux IAM / lux.id) ---
NEXT_PUBLIC_IAM_URL=https://lux.id
NEXT_PUBLIC_IAM_CLIENT_ID=lux-exchange

# --- Backend APIs ---
# CEX matching engine (Go)
NEXT_PUBLIC_CEX_API_URL=http://localhost:8091
# Broker SOR (Go brokerd) — Alpaca, IBKR, etc.
NEXT_PUBLIC_BROKER_API_URL=http://localhost:8090
# KMS
NEXT_PUBLIC_KMS_URL=https://kms.lux.network

# --- Analytics (production only) ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_FB_PIXEL_ID=
# NEXT_PUBLIC_TWITTER_PIXEL_ID=
