iframe.tradeview
  border: none
  outline: none
  overflow: hidden
  width: 100%
  height: 1800px
  padding-top: 4rem
  margin-left: -14px

.trade
  &:before
    content: ''
    display: block
    position: fixed
    width: 100vw
    height: 4rem
    top: 0
    left:0
    background-color: $backgroundDarkColor
    z-index: 100
    pointer-events: none

  &:after
    content: ''
    display: block
    position: fixed
    width: 100vw
    height: 8rem
    top: 4rem
    left:0
    background: linear-gradient(to bottom, $backgroundDarkColor 0%, rgba(19,21,30,.25) 50%, rgba(19,21,30,0) 100%)
    z-index: 10
    pointer-events: none

  max-height: 100vh
  height: 100vh
  background-color: $backgroundDarkColor
  z-index: 2
  position: relative
