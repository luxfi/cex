.hero-text
  text-align: center;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: white;
  max-width: 1200px;
  img
    width: 80%

.container
  width: 60% !important
  margin-right: auto !important
  margin-left: auto !important
  margin-top: 5% !important
  margin-bottom: 5% !important
  padding: 40px 0
  min-width: 1200px

  h6
    line-height: 1.5em

.market-container
  position: relative
  width: 60%
  margin-right: auto
  margin-left: auto
  padding: 20px
  margin-top: 5%
  margin-bottom: 5%
  min-width: 1200px
  .white
    color: white

  .center
    text-align: center

  .market-card-content
    height: 300px
    min-width: 200px
    h5
      text-align: center

  img
    height: 80px
    display: block
    margin: 20px auto

  img.intel
    height: 600px

  h5
    color: black;
    padding-bottom: 10px;

  p
    color: black

  .market-card
    background-color: #F3D952;
    min-width: 250px;

  .nav-bar.scrolled
    background-color: #fff !important;
    transition: background-color 200ms linear;

.vcenter
  margin: auto
  padding: 20% 0%

@media (max-width: 400px)
  .index-container
    width:100%
    max-width: 400px

  .hero-text
    min-width: 250px !important
    width: 100%
    h2
      padding: 0 5%
      margin: 0 auto;
    h6
      padding: 0 5%
      margin: 0 auto;
    img
      width: 80%

  .turnkey-container
    width: 90% !important
    min-width: 250px !important
    width: 100%

  .container
    width: 90% !important
    min-width: 250px !important

  .market-container
    width: 90%
    min-width: 250px !important

  img.intel
    height: auto !important


.footer-container 
  .market-container ul li
    list-style: none

li
  color: #ab974a
