#index
  .login
    max-width: 400px
    padding: 0

    .inputs
      margin-bottom: .5rem
      margin-top: 4rem

    .checkbox
      margin: 1rem auto 1rem
      width: 100%

      .checkbox-container
        flex-direction: column


.index-container
  height: auto
  position: absolute
  margin-bottom: 100px

.hero-image
  background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/static/img/beautiful-light-los-angeles-downtown-city-skyline-P4LBSR5.jpg')
  width: 100%;
  background-position: center;
  background-repeat: no-repeat;
  background-size: cover;
  position: relative;
  height: 100vh

